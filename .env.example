# ============================================================
# AI Agency — Environment Variables
# Copy this file to .env and fill in your values.
# DO NOT commit .env to version control.
# ============================================================

# ── LLM Providers ──────────────────────────────────────────
# Primary: Anthropic (recommended)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Fallback: OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=https://api.openai.com/v1  # for proxies

# Local fallback: Ollama
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3
OLLAMA_API_KEY=ollama

# Provider fallback order (comma-separated)
# LLM_PROVIDER_ORDER=anthropic,openai,ollama

# ── Web Search ──────────────────────────────────────────────
TAVILY_API_KEY=tvly-...
SERP_API_KEY=  # for Google search via SerpAPI

# ── Email ──────────────────────────────────────────────────
# Option A: SMTP (e.g. Gmail, Mailgun, Postmark)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=agency@yourdomain.com

# Option B: SendGrid (alternative to SMTP)
SENDGRID_API_KEY=SG....

# ── File Storage ───────────────────────────────────────────
# Option A: Local filesystem (default, ./storage)
# STORAGE_TYPE=local
# LOCAL_STORAGE_PATH=./storage

# Option B: AWS S3
# S3_BUCKET=my-agency-assets
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=us-east-1
# S3_PREFIX=assets/
# PUBLIC_FILE_URL=https://cdn.myagency.com

# ── Google Sheets ──────────────────────────────────────────
# For data specialist and account team integrations
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# Service account needs Sheets read/write access

# ── Ads APIs ───────────────────────────────────────────────
# Meta / Facebook Ads
# META_ACCESS_TOKEN=EAAAF...

# Google Ads (requires Google Ads API setup)
# GOOGLE_ADS_DEVELOPER_TOKEN=...

# ── IMAP (Inbound Email Ingestion) ────────────────────────
# Optional: Poll an inbox for client emails to auto-create tasks
# IMAP_HOST=imap.gmail.com
# IMAP_USER=agency-inbox@yourdomain.com
# IMAP_PASSWORD=...

# ── CEO / Monitoring ──────────────────────────────────────
# How often the CEO Brain runs MONITOR mode (seconds)
CEO_MONITOR_INTERVAL_SECONDS=300
# Campaign health score below this triggers a warning
HEALTH_SCORE_WARNING_THRESHOLD=70
# SLA breach hours before escalation to human
SLA_BREACH_ESCALATION_HOURS=48

# ── FastAPI Server ─────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false

# ── RawWebsite Git Publish ───────────────────────────────────────────────────
# How approved posts are published to rawwebsite:
#   git_commit    = clone repo, write blog HTML, commit & push  ← recommended
#   manual_export = write HTML+JSON to POST_EXPORT_DIR (debug only)
#   api_publish   = POST to RAWWEBSITE_API_ENDPOINT
RAWWEBSITE_PUBLISH_MODE=git_commit

# Git remote (public URL, token embedded via GIT_TOKEN)
RAWWEBSITE_REPO_URL=https://github.com/liemdo28/rawwebsite.git
RAWWEBSITE_REPO_BRANCH=main

# Optional: local clone path (auto-clones if not set or path invalid)
RAWWEBSITE_REPO_PATH=E:/Project/Master/RawWebsite

# Git author for commits
GIT_AUTHOR_NAME=AgentAI Agency
GIT_AUTHOR_EMAIL=agency@rawsushibar.com

# GitHub PAT with repo:write scope — used for push authentication
#   Format: ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#   Create at: https://github.com/settings/tokens
GIT_TOKEN=

# Local export directory (also used as clone destination if RAWWEBSITE_REPO_PATH not set)
POST_EXPORT_DIR=E:/Project/Master/agentai-agency/post_exports
# All credentials MUST be set here. No hardcoding allowed.
# ============================================================

# ── Agency API ──────────────────────────────────────────────
AGENCY_BASE_URL=http://localhost:8000
AGENCY_TIMEOUT=10

# ── TaskFlow (dashboard.bakudanramen.com) ───────────────────
# Session-based login. Required for all TaskFlow actions.
TASKFLOW_BASE_URL=https://dashboard.bakudanramen.com
TASKFLOW_USERNAME=your_taskflow_email@example.com
TASKFLOW_PASSWORD=your_taskflow_password
TASKFLOW_TIMEOUT=60

# ── Marketing (marketing.bakudanramen.com) ──────────────────
# Bearer API token. Generate via:
# POST https://marketing.bakudanramen.com/api/auth/token
# POST https://marketing.bakudanramen.com/api/auth/key
MARKETING_BASE_URL=https://marketing.bakudanramen.com
MARKETING_API_TOKEN=your_marketing_bearer_token_here
MARKETING_TIMEOUT=120

# ── Growth Dashboard (DreamHost PHP API) ───────────────────
# Branch-state.php and analytics.php endpoints — served from marketing.bakudanramen.com
GROWTH_BASE_URL=https://marketing.bakudanramen.com/api
GROWTH_API_KEY=gdr_...
GROWTH_TIMEOUT=60

# ── Integration Full (Toast-QB sync, local) ─────────────────
# Timeouts for long-running sync operations (in seconds)
INTEGRATION_TIMEOUT=300

# ── Job Queue Defaults ──────────────────────────────────────
JOB_MAX_RETRIES=3
JOB_BACKOFF_SECONDS=10
JOB_DEFAULT_TIMEOUT=300

# ── File Upload ─────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=50

# ── Unified API ────────────────────────────────────────────
UNIFIED_PORT=8001

# ── Dashboard Web Server ─────────────────────────────────────
DASHBOARD_PORT=8080

# ── Security ────────────────────────────────────────────────
SECRET_KEY=change_me_to_random_secret_in_production
